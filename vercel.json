{
  "buildCommand": "npm install && cd frontend/dashboard-admin && npm install && npx vite build",
  "outputDirectory": "frontend/dashboard-admin/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/health",   "destination": "/api/index.js" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}