# ============================================================
# LeadCapture Pro — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env com valores reais no repositório
# ============================================================

# ── Supabase (obrigatório) ────────────────────────────────────
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=sua-service-role-key-aqui

# ── Frontend Supabase (obrigatório) ──────────────────────────
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# ── API URL (frontend aponta para o backend) ─────────────────
VITE_API_URL=https://leadcapture-proprod.vercel.app

# ── Email — Resend (recomendado, emails em 2s) ────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=LeadCapture Pro <noreply@seudominio.com.br>

# ── Email — SMTP Gmail (fallback se não tiver Resend) ─────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-gmail

# ── Notificações ──────────────────────────────────────────────
NOTIFICATION_EMAIL=seu-email@gmail.com
DASHBOARD_URL=https://leadcapture-proprod.vercel.app

# ── WhatsApp — Evolution API ──────────────────────────────────
EVOLUTION_API_URL=http://seu-vps-ip:8080
EVOLUTION_API_KEY=sua-chave-aqui
EVOLUTION_INSTANCE=lead-pro

# ── IA — Anthropic (chatbot) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Monitoramento — Sentry ────────────────────────────────────
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# ── Automação — N8N (opcional) ────────────────────────────────
N8N_WEBHOOK_URL=https://seu-n8n.com/webhook/leads

# ── CORS — Domínios permitidos (separados por vírgula) ────────
CORS_ORIGINS=https://seudominio.com,https://www.seudominio.com

# ── Multi-tenant ──────────────────────────────────────────────
DEFAULT_TENANT_ID=uuid-do-tenant-padrao

# ── Sistema ───────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
